# =================================================
# Supabase (REQUIRED untuk Next.js)
# =================================================
# Diambil dari Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=PASTE_ANON_PUBLIC_KEY_HERE

# =================================================
# Service Role Key (SERVER-ONLY, RAHASIA!)
# =================================================
# JANGAN PERNAH commit nilai asli ke git. Tanpa prefix NEXT_PUBLIC_,
# Next.js TIDAK akan mem-bundle ke browser. Diambil dari Supabase
# Dashboard → Project Settings → API → "service_role" (secret).
# Dipakai oleh /api/admin/users untuk membuat user baru di Supabase Auth.
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

# =================================================
# Hanya untuk skrip "npm run db:apply" (lokal)
# =================================================
# Connection string DB (Project Settings → Database → Connection string).
# TIDAK perlu di-set di Vercel — skrip db:apply hanya jalan di mesin dev.
# Contoh: postgresql://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=
