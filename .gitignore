# Supabase CLI artefak lokal
# =====================================================================
supabase/.branches/
supabase/.temp/
supabase/.env
supabase/.env.local

# Smoke test / debug helper sementara (tidak perlu masuk repo)
supabase/tests/_smoke_*.sql
supabase/tests/_seed_*.sql

